{
  "name": "plasico",
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "plasico/plasico.bg",
  "rewrites": [
    { "source": "/", "destination": "/hot-summer-sale-2026.html" },
    { "source": "/hot-summer-sale-2026", "destination": "/hot-summer-sale-2026.html" }
  ],
  "headers": [
